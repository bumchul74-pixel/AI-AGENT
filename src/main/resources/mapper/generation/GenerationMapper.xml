<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hanwha.ai.generation.mapper.GenerationMapper">
    <resultMap id="generationHistoryResultMap" type="com.hanwha.ai.generation.domain.GenerationHistory">
        <id column="id" property="id" />
        <result column="target_type" property="targetType" />
        <result column="target_types_json" property="targetTypesJson" />
        <result column="prompt" property="prompt" />
        <result column="project_key" property="projectKey" />
        <result column="project_structure" property="projectStructure" />
        <result column="rag_documents_json" property="ragDocumentsJson" />
        <result column="generated_code" property="generatedCode" />
        <result column="llm_provider" property="llmProvider" />
        <result column="llm_model" property="llmModel" />
        <result column="neo4j_index_status" property="neo4jIndexStatus" />
        <result column="neo4j_indexed_at" property="neo4jIndexedAt" />
        <result column="neo4j_index_error" property="neo4jIndexError" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <sql id="generationHistoryColumns">
        id,
        target_type,
        target_types::text AS target_types_json,
        prompt,
        project_key,
        project_structure,
        rag_documents::text AS rag_documents_json,
        generated_code,
        llm_provider,
        llm_model,
        neo4j_index_status,
        neo4j_indexed_at,
        neo4j_index_error,
        created_at
    </sql>

    <sql id="generationHistorySummaryColumns">
        id,
        target_type,
        target_types::text AS target_types_json,
        prompt,
        project_key,
        NULL AS project_structure,
        NULL AS rag_documents_json,
        NULL AS generated_code,
        llm_provider,
        llm_model,
        neo4j_index_status,
        neo4j_indexed_at,
        neo4j_index_error,
        created_at
    </sql>

    <sql id="generationHistorySearchWhere">
        <where>
            <if test="search != null and search.id != null">
                AND id = #{search.id}
            </if>
            <if test="search != null and search.targetType != null">
                AND target_type ILIKE CONCAT('%', #{search.targetType}, '%')
            </if>
            <if test="search != null and search.targetTypes != null">
                AND target_types::text ILIKE CONCAT('%', #{search.targetTypes}, '%')
            </if>
            <if test="search != null and search.prompt != null">
                AND prompt ILIKE CONCAT('%', #{search.prompt}, '%')
            </if>
            <if test="search != null and search.projectStructure != null">
                AND project_structure ILIKE CONCAT('%', #{search.projectStructure}, '%')
            </if>
            <if test="search != null and search.ragDocuments != null">
                AND rag_documents::text ILIKE CONCAT('%', #{search.ragDocuments}, '%')
            </if>
            <if test="search != null and search.generatedCode != null">
                AND generated_code ILIKE CONCAT('%', #{search.generatedCode}, '%')
            </if>
            <if test="search != null and search.llmProvider != null">
                AND llm_provider ILIKE CONCAT('%', #{search.llmProvider}, '%')
            </if>
            <if test="search != null and search.llmModel != null">
                AND llm_model ILIKE CONCAT('%', #{search.llmModel}, '%')
            </if>
            <if test="search != null and search.createdFrom != null">
                AND created_at &gt;= #{search.createdFrom}
            </if>
            <if test="search != null and search.createdTo != null">
                AND created_at &lt; #{search.createdTo}
            </if>
        </where>
    </sql>

    <insert id="insert"
            parameterType="com.hanwha.ai.generation.domain.GenerationHistory"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO generation_history (
            target_type,
            target_types,
            prompt,
            project_key,
            project_structure,
            rag_documents,
            generated_code,
            llm_provider,
            llm_model
        ) VALUES (
            #{targetType},
            CAST(#{targetTypesJson} AS jsonb),
            #{prompt},
            #{projectKey},
            #{projectStructure},
            CAST(#{ragDocumentsJson} AS jsonb),
            #{generatedCode},
            #{llmProvider},
            #{llmModel}
        )
    </insert>

    <update id="updateNeo4jIndexStatus">
        UPDATE generation_history
        SET neo4j_index_status = #{status},
            neo4j_indexed_at = #{indexedAt},
            neo4j_index_error = #{error}
        WHERE id = #{id}
    </update>

    <select id="findAll" resultMap="generationHistoryResultMap">
        SELECT
        <include refid="generationHistorySummaryColumns" />
        FROM generation_history
        <include refid="generationHistorySearchWhere" />
        ORDER BY created_at DESC, id DESC
    </select>

    <select id="findById" parameterType="long" resultMap="generationHistoryResultMap">
        SELECT
        <include refid="generationHistoryColumns" />
        FROM generation_history
        WHERE id = #{id}
    </select>
</mapper>
